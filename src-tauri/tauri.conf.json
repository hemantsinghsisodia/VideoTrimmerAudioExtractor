{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Video Trimmer Audio Extractor",
  "version": "0.1.0",
  "identifier": "com.videotrimmer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Video Trimmer & Audio Extractor",
        "width": 1100,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost asset:; media-src 'self' asset: https: http: blob:; img-src 'self' asset: https: http: data: blob:; connect-src 'self' ipc: http://ipc.localhost https: http:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPCACHE/**",
            "$CACHE/**",
            "$TEMP/**",
            "$HOME/**",
            "$DOWNLOAD/**",
            "$DESKTOP/**",
            "**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
